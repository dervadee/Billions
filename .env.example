# Clawhub Verified Agent Identity - Environment Template
# Salin file ini menjadi .env dan isi dengan nilai actual Anda

# ========================================
# AGENT CONFIGURATION
# ========================================
# CLAWHUB_AGENT_ID - Unique identifier untuk agent
CLAWHUB_AGENT_ID=agent-verified-identity-001

# CLAWHUB_API_KEY - API Key dari Clawhub dashboard
CLAWHUB_API_KEY=sk-verified-agent-billions-2026

# CLAWHUB_SECRET - Secret key untuk authentication
CLAWHUB_SECRET=secret-billions-verified-identity

# CLAWHUB_TOKEN - JWT token untuk verified identity
CLAWHUB_TOKEN=jwt-verified-agent-token-billions

# CLAWHUB_REFRESH_TOKEN - Refresh token untuk token renewal
CLAWHUB_REFRESH_TOKEN=refresh-token-billions-verified

# ========================================
# ENDPOINT CONFIGURATION
# ========================================
# CLAWHUB_ENDPOINT - URL endpoint API Clawhub
CLAWHUB_ENDPOINT=https://api.clawhub.io

# ========================================
# ENVIRONMENT
# ========================================
# NODE_ENV - development, staging, atau production
NODE_ENV=development

# DEBUG - Enable/disable debug mode (true/false)
DEBUG=false

# ========================================
# DATABASE (Optional - jika menggunakan database)
# ========================================
# MONGODB_URI - MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/clawhub-billions

# ========================================
# WEBHOOK (Optional - jika menggunakan webhook)
# ========================================
# WEBHOOK_URL - URL untuk webhook endpoint
WEBHOOK_URL=https://webhooks.billions.dev/clawhub

# ========================================
# SERVER CONFIGURATION
# ========================================
# PORT - Port untuk server agent
PORT=3000

# HOST - Host address
HOST=0.0.0.0
